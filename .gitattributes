# GitHub Linguist classification.
#
# Count the Rust/WASM web migration and published client libraries. Keep the
# legacy React web/dashboard trees available for production builds until routes
# are fully promoted, but exclude them from language stats so replaced UI code
# does not hide Rust migration progress.
/crates/slskr-web/** linguist-vendored=false
/client-ts/src/** linguist-vendored=false

/web/src/** linguist-vendored
/web/public/** linguist-vendored
/dashboard/src/** linguist-vendored
/dashboard/public/** linguist-vendored

/dashboard/dist/** linguist-generated
/web/build/** linguist-generated
/web/coverage/** linguist-generated
/dashboard/coverage/** linguist-generated
/client-ts/dist/** linguist-generated

/web/package-lock.json linguist-generated
/dashboard/package-lock.json linguist-generated
/client-ts/package-lock.json linguist-generated

/web/node_modules/** linguist-vendored
/dashboard/node_modules/** linguist-vendored
/client-ts/node_modules/** linguist-vendored

/docs/** linguist-documentation
/archive/** linguist-documentation
*.md linguist-documentation
